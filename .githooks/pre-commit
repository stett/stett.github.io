#!/usr/bin/env ruby
# frozen_string_literal: true

require 'fileutils'
require 'open3'
require 'tempfile'
require 'yaml'

def pandoc_available?
  system('pandoc', '--version', out: File::NULL, err: File::NULL)
end

def parse_frontmatter(path)
  content = File.read(path, encoding: 'utf-8')
  return {} unless content.start_with?('---')

  match = content.match(/\A---\r?\n(.*?)\r?\n---\r?\n/m)
  return {} unless match

  YAML.safe_load(match[1]) || {}
rescue StandardError
  {}
end

def convert_tables(content)
  # Convert headerless pipe tables (no |---|---| separator) to raw LaTeX tabular.
  # Pandoc requires a header separator row to recognise pipe tables; without one it
  # renders the | characters as literal text.
  content.gsub(/^(\|[^\n]+\n)+/) do |block|
    lines = block.split("\n").reject(&:empty?)
    # Leave standard pandoc tables (those that have a separator row) untouched
    next block if lines.any? { |l| l.match?(/^\|[\s:|-]+\|/) }

    rows = lines.map do |l|
      l.split('|').map(&:strip).reject(&:empty?).map do |cell|
        cell.gsub(/\[([^\]]+)\]\([^)]+\)/, '\1')  # strip markdown links to plain text
      end
    end

    "\\begin{table*}[h]\n\\begin{tabular}{@{}lp{0.65\\linewidth}@{}}\n" +
      rows.map { |cells| cells.join(' & ') + ' \\\\' }.join("\n") +
      "\n\\end{tabular}\n\\end{table*}\n\n"
  end
end

def strip_jekyll(content)
  # Strip YAML frontmatter — pandoc re-parses it and chokes on --- rules in the body
  content = content.sub(/\A---\r?\n.*?\r?\n---\r?\n/m, '')
  content
    .gsub(/<video\b[^>]*>.*?<\/video\s*>/im, '')
    .gsub(/<source\b[^>]*\/?>/, '')
    .gsub(/\{%-?\s*.*?\s*-?%\}/m, '')
    .gsub(/\{\{[^}]*\}\}/, '')
    .gsub(/^---$/, '* * *')  # --- in body would be read as a YAML delimiter by pandoc
    .then { |c| convert_tables(c) }
end

unless pandoc_available?
  puts 'pre-commit: pandoc not found, skipping PDF generation'
  exit 0
end

changed = `git diff --cached --name-only --diff-filter=ACM`.split("\n")

changed.each do |file|
  next unless file.match?(%r{^(_posts|_drafts)/.*\.md$})
  next unless File.exist?(file)

  fm = parse_frontmatter(file)
  next unless fm['pdf']

  puts "pre-commit: generating PDF for #{file}"

  FileUtils.mkdir_p('assets/pdf')
  outfile = "assets/pdf/#{File.basename(file, '.md')}.pdf"

  Tempfile.create(['jekyll-pdf', '.md']) do |tmp|
    tmp.write(strip_jekyll(File.read(file, encoding: 'utf-8')))
    tmp.flush

    stderr = nil
    status = nil

    Tempfile.create(['jekyll-pdf-header', '.tex']) do |hdr|
      hdr.write(<<~'LATEX')
        \usepackage{stfloats}
        \usepackage{fvextra}
        \DefineVerbatimEnvironment{Highlighting}{Verbatim}{commandchars=\\\{\},breaklines=true,fontsize=\small}
      LATEX
      hdr.flush

      _, stderr, status = Open3.capture3(
        'pandoc', tmp.path,
        '--from', 'markdown+tex_math_dollars',
        '--pdf-engine=xelatex',
        '-H', hdr.path,
        '-V', 'classoption=twocolumn',
        '-V', 'geometry:margin=1in',
        '-V', 'fontsize=10pt',
        '-M', "title:#{fm['title'] || File.basename(file, '.md')}",
        '-o', outfile
      )
    end

    if status.success?
      system('git', 'add', outfile)
      puts "pre-commit: added #{outfile} to commit"
    else
      warn "pre-commit: PDF generation failed for #{file}\n#{stderr}"
    end
  end
end
